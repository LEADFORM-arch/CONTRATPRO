# ContratPro local development template.
# Copy to .env.local and fill real local values from Supabase, Resend, Stripe and GoCardless.
# Never commit .env.local.

NEXT_PUBLIC_APP_URL=http://localhost:3000
CONTRATPRO_APP_URL=http://localhost:3000

CONTRATPRO_REQUIRE_AUTH=true
CONTRATPRO_RLS_ENABLED=true
CONTRATPRO_REQUIRE_BILLING=false
CONTRATPRO_ADMIN_EMAILS=admin@votre-domaine.fr
CONTRATPRO_NOTIFICATION_EMAILS=admin@votre-domaine.fr
# Never use org_demo when VERCEL_ENV or NODE_ENV is production.
# Local admin/pilot organization used for authenticated development.
CONTRATPRO_ORG_ID=org_contratpro_admin
CONTRATPRO_PUBLIC_LEAD_ORG_ID=org_contratpro_admin

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

RESEND_API_KEY=
RESEND_FROM_EMAIL=ContratPro <documents@votre-domaine.fr>

GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_ENVIRONMENT=sandbox
GOCARDLESS_VERSION=2015-07-06
GOCARDLESS_WEBHOOK_ENDPOINT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=
# Legacy fallback for the Pro plan.
STRIPE_PRICE_ID=

CRON_SECRET=
CONTRATPRO_CRON_SECRET=
