# ContratPro production environment template.
# Never commit real secrets. Copy values into Vercel Project Settings > Environment Variables.

NEXT_PUBLIC_APP_URL=https://app.contratpro.fr
CONTRATPRO_APP_URL=https://app.contratpro.fr

CONTRATPRO_REQUIRE_AUTH=true
CONTRATPRO_RLS_ENABLED=true
CONTRATPRO_REQUIRE_BILLING=true
CONTRATPRO_ADMIN_EMAILS=admin@votre-domaine.fr
CONTRATPRO_NOTIFICATION_EMAILS=admin@votre-domaine.fr
CONTRATPRO_ORG_ID=
CONTRATPRO_PUBLIC_LEAD_ORG_ID=

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

RESEND_API_KEY=
RESEND_FROM_EMAIL=ContratPro <documents@votre-domaine.fr>

GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_ENVIRONMENT=live
GOCARDLESS_VERSION=2015-07-06
GOCARDLESS_WEBHOOK_ENDPOINT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=
# Legacy fallback for the Pro plan.
STRIPE_PRICE_ID=

# Vercel Cron sends this value in Authorization: Bearer $CRON_SECRET.
# CONTRATPRO_CRON_SECRET is also supported for local/external schedulers.
CRON_SECRET=
CONTRATPRO_CRON_SECRET=
